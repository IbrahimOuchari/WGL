<odoo>
    <data>
        <record id="view_mrp_bom_tree_inherit_state" model="ir.ui.view">
            <field name="name">mrp.bom.tree.inherit.state</field>
            <field name="model">mrp.bom</field>
            <field name="inherit_id" ref="nn_reporting.mrp_bom_product_cost"/>
            <field name="arch" type="xml">
                <!-- Add 'state' field as a new column after 'product_tmpl_id' column -->


                <xpath expr="//tree/field[@name='product_tmpl_id']" position="before">
                    <field name="create_date"/>
                        </xpath>
                <xpath expr="//tree" position="inside">
                    <field name="state" string="État"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
