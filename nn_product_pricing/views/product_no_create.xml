<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_case_form_view_oppor_inherit_product_no_create" model="ir.ui.view">
        <field name="name">crm.lead.oppor.inherited.no.create</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="bmg_crm.crm_case_form_view_oppor_inherit_product"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>
    <record id="inherit_sale_order_template_product_no_create" model="ir.ui.view">
        <field name="name">sale.order.template.form.inherit.product.options</field>
        <field name="model">sale.order.template</field>
        <field name="inherit_id" ref="sale_management.sale_order_template_view_form"/>
        <field name="arch" type="xml">

            <!-- Target the tree product_id inside order lines -->
            <xpath expr="//page[@name='order_lines']//field[@name='sale_order_template_line_ids']//tree//field[@name='product_id']"
                   position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>

        </field>

    </record>
    <record id="inherit_purchase_order_product_no_create" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.product.options</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- product_id inside purchase order lines -->
            <xpath expr="//page[@name='products']//field[@name='order_line']//tree//field[@name='product_id']"
                   position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>

        </field>
    </record>
    <record id="inherit_supplierinfo_product_no_create" model="ir.ui.view">
