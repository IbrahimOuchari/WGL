<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mrp_production_form_view_inherit_cancel_group" model="ir.ui.view">
        <field name="name">mrp.production.form.cancel.group</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_cancel'][1]" position="attributes">
                <attribute name="groups">nn_mrp_cancel_group.group_mrp_cancel</attribute>
            </xpath>

            <xpath expr="//button[@name='action_cancel'][2]" position="attributes">
                <attribute name="groups">nn_mrp_cancel_group.group_mrp_cancel</attribute>
            </xpath>

        </field>
    </record>

</odoo>